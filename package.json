{
  "name": "ascii-vampire-survivors",
  "version": "0.1.0",
  "private": true,
  "description": "A Vampire-Survivors-style ASCII game that runs in your terminal.",
  "type": "module",
  "engines": {
    "node": ">=22.18.0"
  },
  "scripts": {
    "start": "node src/main.ts",
    "dev": "node src/main.ts --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "test": "node --test src/tests/*.test.ts",
    "web": "node src/serve.ts",
    "build:web": "tsc -p tsconfig.web.json && node src/tools/pack.ts",
    "bench": "node src/bench.ts"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "typescript": "^5.9.3"
  }
}
